  "private": true,
  "description": "Open-source browser, enrichment & CARE export for NRCeS Common Drug Codes for India (SNOMED CT)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build:data": "tsx scripts/build-data.ts",
    "validate:enrichments": "tsx scripts/validate-enrichments.ts",
